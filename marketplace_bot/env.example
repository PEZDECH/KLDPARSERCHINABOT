# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# Database
# Для SQLite: sqlite+aiosqlite:///./bot.db
# Для PostgreSQL: postgresql+asyncpg://user:password@localhost/dbname
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# Proxy Settings (опционально)
# Формат: http://user:pass@host:port или http://host:port
HTTP_PROXY=
HTTPS_PROXY=

# Playwright Settings
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# Scraping Settings
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_DELAY=2

# Scheduler Settings
PARSING_INTERVAL_MINUTES=5

# Logging
LOG_LEVEL=INFO
